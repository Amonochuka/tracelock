# ----------------------------
# Go build / binary files
# ----------------------------
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ----------------------------
# SQL / Database
# ----------------------------
# Ignore database dump files (backups, exports)
dumps/*.sql
*.db
*.sqlite3
tmp/
db/backups/

# ----------------------------
# Migrations (tracked)
# ----------------------------
# Only track migration/schema files
#migrations/*.sql <-- keep these tracked!

# ----------------------------
# Environment / config
# ----------------------------
.env          # your local environment variables
.env.local    # optional local overrides

# ----------------------------
# IDE / Editor files
# ----------------------------
.vscode/
.idea/
*.swp
*.DS_Store.env
.env
